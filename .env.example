# CrawlTrove local configuration. Every setting is optional.

# Authentication (recommended before changing BIND_ADDRESS from loopback).
# APP_USERNAME=admin
# APP_PASSWORD=
# API_KEYS=

# Docker Compose host bind. The default is local-only.
# BIND_ADDRESS=127.0.0.1
# ALLOW_UNAUTHENTICATED=false

# Explicitly allow scraping localhost and private-network targets.
# Never enable this for an instance that accepts untrusted URLs.
# ALLOW_PRIVATE_NETWORKS=false

# Comma-separated browser origins. CORS is disabled when unset.
# CORS_ORIGINS=https://app.example.com

# The supported Docker Compose stack always uses its bundled PostgreSQL so the
# core and auto-enrolled workers share one durable database. Standalone and
# managed deployments may set DATABASE_URL directly.

# Structured extraction / research backends.
# LOCAL_LLM_BASE_URL=http://host.docker.internal:8081
# LOCAL_LLM_MODEL=local
# LOCAL_LLM_API_KEY=
# ANTHROPIC_API_KEY=
# AI_GATEWAY_API_KEY=

# Semantic embeddings.
# EMBEDDINGS_BASE_URL=
# EMBEDDINGS_MODEL=
# EMBEDDINGS_API_KEY=

# Optional web search providers; DuckDuckGo is the keyless fallback.
# SEARXNG_BASE_URL=
# BRAVE_SEARCH_API_KEY=

# Completion webhooks.
# WEBHOOK_URL=
# WEBHOOK_SECRET=

# LOG_LEVEL=INFO
# LOG_FORMAT=json

# Chromium is sandboxed by default. Disable only for a trusted local runtime
# that cannot support the sandbox; never use this for untrusted pages.
# CHROMIUM_DISABLE_SANDBOX=false

# Remote worker process. Enrollment bundles normally supply worker identity,
# PostgreSQL client certificates, and S3 credentials; do not commit a bundle.
# CRAWLTROVE_ROLE=worker
# CRAWLTROVE_WORKER_ID=
# WORKER_HEALTH_HOST=127.0.0.1
# WORKER_HEALTH_PORT=8081
# WORKER_ALLOW_INSECURE_DB=false

# S3-compatible immutable artifact storage (required for remote workers).
# ARTIFACT_STORE_BACKEND=s3
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Optional first-party image/text CAPTCHA solving. This is disabled unless an
# operator allowlists exact hosts (or explicit non-public-suffix subdomains).
# Token challenges such as reCAPTCHA, hCaptcha, and Turnstile always require a
# human or an approved managed provider.
# CAPTCHA_AUTHORIZED_DOMAINS=example.com,*.docs.example.com
# CAPTCHA_SOLVER_MIN_CONFIDENCE=0.80
# CAPTCHA_SOLVER_URL=https://captcha-solver.internal/solve
# CAPTCHA_SOLVER_TOKEN_FILE=/run/secrets/captcha-solver-token  # mode 0600; also service auth
